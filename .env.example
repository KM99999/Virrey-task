# --- Math IA · configuración ---
# Copia este archivo a ".env" y rellena tu clave real.
# El archivo .env NUNCA se sube al repositorio (ver .gitignore).

# Clave de la API de Google Gemini (obligatoria).
# Consíguela en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelo de Gemini a usar (opcional). Por defecto: gemini-flash-latest
# (alias auto-actualizable; si Google retira un modelo hay fallback automático).
GEMINI_MODEL=gemini-flash-latest

# Puerto del servidor (opcional). Por defecto: 3000
PORT=3000
